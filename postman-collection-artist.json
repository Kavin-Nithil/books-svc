{
  "info": {
    "name": "Record Label Artists API",
    "_postman_id": "rl-artists-api-8001",
    "description": "Complete Postman collection for the Record Label Artists API running on port 8001.\n\n**Base URL:** `http://localhost:8001`\n\n**Authentication:** HTTP Basic Auth on every request.\n\n| Username | Password |\n|---|---|\n| `admin` | `secret123` |\n| `readonly` | `readpass` |\n\n**Endpoints:**\n- `GET  /v1/artists`              — Paginated list of artists\n- `POST /v1/artists`              — Create a new artist\n- `GET  /v1/artists/{artistName}` — Get artist by name\n\n**Run the server first:**\n```\nuvicorn app:app --reload --port 8001\n```",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8001",
      "type": "string",
      "description": "Base URL — change to your server address if needed"
    },
    {
      "key": "username",
      "value": "admin",
      "type": "string",
      "description": "Basic Auth username"
    },
    {
      "key": "password",
      "value": "secret123",
      "type": "string",
      "description": "Basic Auth password"
    },
    {
      "key": "artist_name",
      "value": "Arctic Beats",
      "type": "string",
      "description": "Artist name used in GET /v1/artists/{artistName}"
    }
  ],
  "auth": {
    "type": "basic",
    "basic": [
      { "key": "username", "value": "{{username}}", "type": "string" },
      { "key": "password", "value": "{{password}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Unauthenticated health check. Returns server status and total artist count."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Status is ok', () => {",
                  "    pm.expect(pm.response.json().status).to.equal('ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "GET /v1/artists — List Artists",
      "description": "Paginated list of all artists. Requires Basic Auth.\n\nQuery params:\n- `offset` — zero-based start index (default 0, min 0)\n- `limit`  — page size (default 20, range 1–100)",
      "item": [
        {
          "name": "List Artists — Default Pagination",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/artists",
              "host": ["{{base_url}}"],
              "path": ["v1", "artists"]
            },
            "description": "Returns the first page of artists using default pagination (offset=0, limit=20)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has pagination fields', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.all.keys('items', 'offset', 'limit', 'total');",
                  "});",
                  "pm.test('items is an array', () => {",
                  "    pm.expect(pm.response.json().items).to.be.an('array');",
                  "});",
                  "pm.test('Each artist has required fields', () => {",
                  "    const items = pm.response.json().items;",
                  "    if (items.length > 0) {",
                  "        pm.expect(items[0]).to.have.all.keys('name', 'genre', 'albumsPublished', 'username');",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Artists — Custom Offset & Limit",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/artists?offset=2&limit=3",
              "host": ["{{base_url}}"],
              "path": ["v1", "artists"],
