    {
      "name": "POST /v1/artists — Create Artist",
      "description": "Creates a new artist record. Both `name` and `username` must be unique.\n\nReturns **201 Created** on success, **409 Conflict** for duplicates, **422** for missing/invalid fields.",
      "item": [
        {
          "name": "Create Artist — Success (201)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Crystal Wave\",\n  \"genre\": \"Synthwave\",\n  \"albumsPublished\": 2,\n  \"username\": \"crystal_wave\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/v1/artists",
              "host": ["{{base_url}}"],
              "path": ["v1", "artists"]
            },
            "description": "Creates a brand new artist. Run once — a second run returns 409 because the name/username already exists.\n\nOn success the response echoes back the saved artist with HTTP 201."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Created artist returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.name).to.equal('Crystal Wave');",
                  "    pm.expect(json.username).to.equal('crystal_wave');",
                  "    pm.expect(json.albumsPublished).to.equal(2);",
                  "});",
                  "pm.test('All required fields present', () => {",
                  "    pm.expect(pm.response.json()).to.have.all.keys('name','genre','albumsPublished','username');",
                  "});"
                ]
              }
            }
          ]
        },
