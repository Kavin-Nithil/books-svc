        {
          "name": "Get Artist — Arctic Beats (200)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/v1/artists/Arctic Beats",
              "host": ["{{base_url}}"],
              "path": ["v1", "artists", "Arctic Beats"]
