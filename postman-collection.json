{
  "info": {
    "name": "Book Info Service — REST, RPC & GraphQL",
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "description": "Complete Postman collection for the Book Info Service demonstrating three API paradigms:\n\n**REST** — Resource-oriented, HTTP verbs, standard status codes (`/books`)\n\n**RPC** — Action-oriented, all POST, response envelope (`/rpc/*`)\n\n**GraphQL** — Single endpoint, client-driven field selection (`/graphql`)\n\n---\n**Base URL:** `http://localhost:8000`\n\nRun the server first:\n```\npip install -r requirements.txt\nuvicorn app:app --reload --port 8000\n```",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string",
      "description": "Base URL of the running FastAPI server"
    },
    {
      "key": "book_id",
      "value": "1",
      "type": "string",
      "description": "Default book ID used in parameterised requests"
    }
  ],
  "item": [
    {
      "name": "Health & Info",
      "item": [
        {
          "name": "Service Root",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            },
            "description": "Returns service metadata and a full map of every endpoint across all three paradigms."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has paradigms key', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('paradigms');",
                  "    pm.expect(json.paradigms).to.have.all.keys('REST','RPC','GraphQL');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "REST — /books",
      "description": "Resource-oriented endpoints. HTTP verbs express intent; status codes communicate outcome.\n\n| Method | Path | Purpose |\n|---|---|---|\n| GET | /books | List all (filterable) |\n| GET | /books/{id} | Single book |\n| POST | /books | Create |\n| PUT | /books/{id} | Update |\n| DELETE | /books/{id} | Delete |",
      "item": [
        {
          "name": "List All Books",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/books",
              "host": ["{{base_url}}"],
              "path": ["books"]
            },
            "description": "Returns all books in the catalogue. Expects HTTP 200 and a JSON array."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "pm.test('Books have required fields', () => {",
                  "    const books = pm.response.json();",
                  "    if (books.length > 0) {",
                  "        pm.expect(books[0]).to.have.all.keys('id','title','author','year','genre');",
                  "    }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Books — Filter by Genre",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/books?genre=Programming",
              "host": ["{{base_url}}"],
              "path": ["books"],
              "query": [
                {
                  "key": "genre",
                  "value": "Programming",
                  "description": "Case-insensitive genre filter"
                }
              ]
            },
            "description": "Filters the book list by genre. Change the `genre` query param to try others (e.g. `Software Engineering`, `Computer Science`)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('All results match genre', () => {",
                  "    pm.response.json().forEach(b => {",
                  "        pm.expect(b.genre.toLowerCase()).to.equal('programming');",
                  "    });",
                  "});"
