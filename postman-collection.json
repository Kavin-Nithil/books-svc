    {
      "name": "RPC — /rpc/*",
      "description": "Action-oriented endpoints — every call uses **POST**. The operation name is in the URL path. HTTP status is always **200**; check the `success` boolean in the envelope for the outcome.\n\n```json\n// Success envelope\n{\"success\": true,  \"data\": {...}, \"error\": null}\n\n// Failure envelope (still HTTP 200)\n{\"success\": false, \"data\": null, \"error\": \"...\"}\n```",
      "item": [
        {
          "name": "listBooks",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/rpc/listBooks",
              "host": ["{{base_url}}"],
              "path": ["rpc", "listBooks"]
            },
            "description": "RPC call to list all books. No body required (or pass `{}`)."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "pm.test('Envelope success=true', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.success).to.be.true;",
                  "    pm.expect(json.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
