                  "pm.test('Schema types returned', () => {",
                  "    const types = pm.response.json().data.__schema.types;",
                  "    pm.expect(types).to.be.an('array');",
                  "    const names = types.map(t => t.name);",
                  "    pm.expect(names).to.include('BookType');",
                  "});"
                ]
              }
            }
          ]
        },
