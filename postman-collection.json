    {
      "name": "GraphQL — /graphql",
      "description": "All GraphQL operations go through the single `/graphql` endpoint.\n\n- **Queries** → read operations (equivalent to GET in REST)\n- **Mutations** → write operations (equivalent to POST/PUT/DELETE in REST)\n- Clients choose **exactly which fields** to return — no over-fetching.\n\nOpen `http://localhost:8000/graphql` in a browser for the interactive **GraphiQL IDE**.",
      "item": [
        {
          "name": "Query — Get Book by ID (all fields)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"{ book(id: 1) { id title author year genre } }\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            },
            "description": "Fetches book with `id=1` requesting all five fields. Change the ID in the query string to fetch other books."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "pm.test('data.book exists', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('data');",
                  "    pm.expect(json.data.book).to.have.all.keys('id','title','author','year','genre');",
                  "});",
                  "pm.test('No GraphQL errors', () => {",
                  "    pm.expect(pm.response.json()).to.not.have.property('errors');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Query — Partial Fields (title + author only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"{ book(id: 2) { title author } }\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/graphql",
              "host": ["{{base_url}}"],
              "path": ["graphql"]
            },
            "description": "Demonstrates GraphQL's **no over-fetching** principle — the server only returns `title` and `author`; `id`, `year`, and `genre` are not transmitted."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP 200', () => pm.response.to.have.status(200));",
                  "pm.test('Only requested fields returned', () => {",
                  "    const book = pm.response.json().data.book;",
                  "    pm.expect(book).to.have.all.keys('title', 'author');",
                  "    pm.expect(book).to.not.have.property('id');",
                  "    pm.expect(book).to.not.have.property('year');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Query — List All Books",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept",       "value": "application/json" }
