    }
  ],
  "item": [
    {
      "name": "Required Assignment Scenarios",
      "description": "Focused requests for the exact Kong gateway cases requested in the assignment brief.",
      "item": [
        {
          "name": "10 Rapid Requests (>5/s) -> 429 Too Many Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{kong_proxy_url}}/books",
              "host": [
                "{{kong_proxy_url}}"
              ],
              "path": [
                "books"
              ]
            },
            "description": "Run this request 10 times quickly in Collection Runner or Newman. Kong limits the Book service to 5 requests per second per IP, so the burst should produce at least one `429 Too Many Requests` response."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 or 429 during burst test', () => {",
                  "  pm.expect([200, 429]).to.include(pm.response.code);",
                  "});",
                  "pm.test('429 responses indicate Kong rate limiting', () => {",
                  "  if (pm.response.code === 429) {",
                  "    pm.expect(pm.response.text()).to.include('API rate limit exceeded');",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "POST with 2 MB Body -> 413 Payload Too Large",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('two_mb_blob', 'X'.repeat(2 * 1024 * 1024));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 413', () => pm.response.to.have.status(413));",
                  "pm.test('Kong size limiting triggered', () => {",
                  "  pm.expect(pm.response.text().toLowerCase()).to.include('payload');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{two_mb_blob}}\",\n  \"author\": \"Gateway Tester\",\n  \"year\": 2024,\n  \"genre\": \"LoadTest\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{kong_proxy_url}}/books",
              "host": [
                "{{kong_proxy_url}}"
              ],
              "path": [
                "books"
              ]
            },
            "description": "Sends a request body larger than 2 MiB to a route capped at 1 MB by Kong's `request-size-limiting` plugin. Expected result: `413 Payload Too Large`."
          },
          "response": []
        },
        {
          "name": "No Authorization Header -> 401 Unauthorized",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [
              {
                "key": "apikey",
                "value": "{{artist_readonly_apikey}}"
              }
            ],
            "url": {
              "raw": "{{kong_proxy_url}}/v1/artists",
              "host": [
                "{{kong_proxy_url}}"
              ],
              "path": [
                "v1",
                "artists"
              ]
            },
            "description": "Sends the request without the HTTP `Authorization` header. Kong forwards the request to `artist_app.py`, whose Basic auth check should reject it with `401 Unauthorized`."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Basic auth challenge is present', () => {",
                  "  pm.expect(pm.response.headers.get('WWW-Authenticate')).to.include('Basic');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Valid Admin Credentials -> 200 OK (Higher Quota)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{artist_basic_user}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{artist_basic_pass}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [
              {
                "key": "apikey",
                "value": "{{artist_admin_apikey}}"
              }
            ],
            "url": {
              "raw": "{{kong_proxy_url}}/v1/artists",
              "host": [
                "{{kong_proxy_url}}"
              ],
              "path": [
                "v1",
                "artists"
              ]
            },
            "description": "Uses the admin consumer key plus valid upstream Basic credentials. Expected result: `200 OK`. This request represents the higher-quota consumer used for the per-consumer override case."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Rate limit header present for higher quota consumer', () => {",
                  "  pm.expect(pm.response.headers.has('X-RateLimit-Limit-Second')).to.equal(true);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Per-Consumer Override Burst Check (Admin vs Readonly)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{kong_proxy_url}}/v1/artists",
              "host": [
                "{{kong_proxy_url}}"
              ],
              "path": [
                "v1",
                "artists"
              ]
            },
            "description": "Use Collection Runner twice: first with header `apikey={{artist_readonly_apikey}}` to hit `429` after about 5 requests/second, then with `apikey={{artist_admin_apikey}}` and Basic auth to confirm the admin consumer continues returning `200` under the same burst because it has a higher quota override."
          },
          "response": []
        }
      ]
    },
